<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvInitial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#80EDF8"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:textColor="#0000FF"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="G" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvReviewerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@+id/tvInitial"
        app:layout_constraintTop_toTopOf="@+id/tvInitial"
        tools:text="Eleanor Collins" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvReviewDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvReviewerName"
        tools:text="4/20/2025" />

    <LinearLayout
        android:id="@+id/llRatings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@+id/tvReviewerName"
        app:layout_constraintTop_toBottomOf="@+id/tvReviewerName">

        <ImageView
            android:id="@+id/ivStar1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_rating" />

        <ImageView
            android:id="@+id/ivStar2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_rate" />

        <ImageView
            android:id="@+id/ivStar3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_rate" />

        <ImageView
            android:id="@+id/ivStar4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_rate" />

        <ImageView
            android:id="@+id/ivStar5"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_rate" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvReviewComment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/tvReviewerName"
        app:layout_constraintTop_toBottomOf="@+id/llRatings"
        tools:text="Would not recommend!" />

</androidx.constraintlayout.widget.ConstraintLayout>